{
  "name": "context-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:mcp": "./pnpm --filter @context-sidecar/mcp test",
    "test:cli": "./pnpm --filter @context-sidecar/cli test",
    "test:e2e": "./pnpm --filter @context-sidecar/api test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "./pnpm exec context-sidecar doctor --json",
    "setup": "bash scripts/bootstrap.sh",
    "doctor": "./pnpm exec context-sidecar doctor --json",
    "eval": "./pnpm --filter @context-sidecar/evals test",
    "demo": "./pnpm exec context-sidecar demo",
    "dev": "bash scripts/dev.sh",
    "dev:api": "./pnpm exec context-sidecar serve api",
    "dev:mcp": "./pnpm exec context-sidecar serve mcp",
    "bootstrap": "bash scripts/bootstrap.sh",
    "serve:mcp": "./pnpm exec context-sidecar serve mcp",
    "serve:api": "./pnpm exec context-sidecar serve api",
    "context": "./pnpm exec context-sidecar context",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@context-sidecar/cli": "workspace:*",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "tsx": "^4.20.6"
  }
}
